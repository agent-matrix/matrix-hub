# =============================================================================
# matrix-hub — production .env template (Aiven primary + OL9 fallback)
#
# 1. cp .env.production.example .env
# 2. fill in the <PLACEHOLDERS>
# 3. NEVER commit the resulting .env (already in .gitignore)
# =============================================================================

# --- Server -----------------------------------------------------------------
APP_NAME=matrix-hub
HOST=0.0.0.0
PORT=443
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://api.matrixhub.io

# --- Auth -------------------------------------------------------------------
# Generate once with: openssl rand -hex 32
API_TOKEN=<GENERATE_AND_PASTE>
REQUIRE_API_TOKEN_IN_PROD=true

# --- Database (primary + fallback selected at boot) -------------------------
#
# scripts/select_database_url.sh probes PRIMARY first; falls back to FALLBACK
# only if PRIMARY is unreachable. Set DATABASE_URL explicitly to bypass.
#
# Primary: Aiven managed Postgres (DigitalOcean SFO).
DATABASE_URL_PRIMARY=postgresql+psycopg://avnadmin:<AIVEN_PASSWORD>@pg-37455d5-matrixhub-db.c.aivencloud.com:24870/defaultdb?sslmode=require

# Fallback: OL9 local Postgres on the VCN private network. Keep wired while
# you're still running OL9 as a hot DR copy; comment out once decommissioned.
DATABASE_URL_FALLBACK=postgresql+psycopg://matrix:<OL9_PASSWORD>@10.0.0.185:5432/matrixhub

# Selector knobs (defaults are sensible — uncomment to tighten):
# PROBE_TIMEOUT=5         # seconds per probe
# PROBE_RETRIES=2         # retries per URL before giving up
# ON_FALLBACK=warn        # warn | require | fail   (fail = refuse to start on stale fallback)

# --- CORS (must include every Vercel host the frontend may serve from) ------
CORS_ALLOW_ORIGINS=["https://matrixhub.io","https://www.matrixhub.io","https://matrixhub.vercel.app"]
CORS_ALLOW_CREDENTIALS=false

# --- Search & ranking (matches frontend defaults) ---------------------------
SEARCH_LEXICAL_BACKEND=pgtrgm        # pg_trgm is provisioned by init_aiven.sh
SEARCH_VECTOR_BACKEND=none           # set to pgvector once you've enabled it on Aiven
SEARCH_DEFAULT_MODE=keyword
SEARCH_INCLUDE_PENDING_DEFAULT=true
SEARCH_HYBRID_WEIGHTS=sem:0.6,lex:0.4,rec:0.1,q:0.1
RAG_ENABLED=false

# --- Catalog ingestion ------------------------------------------------------
CATALOG_REMOTES=["https://raw.githubusercontent.com/agent-matrix/catalog/main/index.json"]
INGEST_SCHED_ENABLED=true
INGEST_INTERVAL_MIN=15

# --- MCP Gateway integration ------------------------------------------------
MCP_GATEWAY_URL=http://127.0.0.1:4444
MCP_GATEWAY_TOKEN=<GENERATE_AND_PASTE>

# --- IBM watsonx (optional) -------------------------------------------------
# WATSONX_API_KEY=
# WATSONX_URL=
# WATSONX_PROJECT_ID=
# MODEL_ID=ibm/granite-3-3-8b-instruct
