# ==============================================================================
# Matrix Hub — environment for local dev (uvicorn / docker compose)
# Copy to ".env" and adjust as needed.
# ==============================================================================

# -------------------------
# Server
# -------------------------
APP_NAME=matrix-hub
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Optional admin API token for protected endpoints (leave blank to disable auth)
API_TOKEN=

# -------------------------
# Database
#
# Two ways to point matrix-hub at a database:
#
# 1. Single explicit URL (simplest — bypasses the startup probe):
#      DATABASE_URL=postgresql+psycopg://user:pw@host/db?sslmode=require
#
# 2. Primary + fallback, picked at startup by scripts/select_database_url.sh:
#      DATABASE_URL_PRIMARY=...   (Aiven managed Postgres — preferred)
#      DATABASE_URL_FALLBACK=...  (OCI OL9 local Postgres, kept as DR)
#
#    docker-entrypoint.sh sources scripts/select_database_url.sh; if the
#    primary is unreachable, the Hub starts against the fallback and exposes
#    MATRIXHUB_DB_USED=fallback so /health and /status can flag the degraded
#    state. Fallback is meant to be temporary — restore the primary before
#    writes start diverging.
#
# Local dev quickstart (SQLite, no Postgres needed):
DATABASE_URL=sqlite+pysqlite:///./data/catalog.sqlite

# Production example (uncomment and fill in real values):
# DATABASE_URL_PRIMARY=postgresql+psycopg://avnadmin:PASSWORD@pg-37455d5-matrixhub-db.c.aivencloud.com:24870/defaultdb?sslmode=require
# DATABASE_URL_FALLBACK=postgresql+psycopg://matrix:PASSWORD@10.0.0.185:5432/matrixhub
# Optional knobs for the selector:
#   PROBE_TIMEOUT=5            # seconds per probe
#   PROBE_RETRIES=2            # retries per URL before giving up
#   ON_FALLBACK=warn           # warn | require | fail
#                              #   fail = refuse to start on stale fallback (production-strict)

# Dev-only convenience: if true and using SQLite, create tables on startup
# (Production: use Alembic migrations instead)
INIT_DB=true

# -------------------------
# Search & ranking
SEARCH_LEXICAL_BACKEND=none          # options: pgtrgm | none
SEARCH_VECTOR_BACKEND=none           # options: pgvector | milvus | none
SEARCH_HYBRID_WEIGHTS=sem:0.6,lex:0.4,rec:0.1,q:0.1
SEARCH_DEFAULT_MODE=keyword          # keep "keyword" until pgtrgm/pgvector are configured
SEARCH_INCLUDE_PENDING_DEFAULT=true
RAG_ENABLED=false
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -------------------------
# Catalog ingestion
CATALOG_REMOTES=["https://raw.githubusercontent.com/agent-matrix/catalog/main/index.json"]
INGEST_INTERVAL_MIN=15

# -------------------------
# MCP Gateway integration
MCP_GATEWAY_URL=http://127.0.0.1:4444
MCP_GATEWAY_TOKEN=supersecret

# -------------------------
# Misc
PIP_INDEX_URL=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# -------------------------
# Default Postgres user/password (used in docker scripts that bootstrap a
# *local* Postgres for development; ignored when DATABASE_URL_PRIMARY points
# at an external managed DB like Aiven)
POSTGRES_USER=matrix
POSTGRES_PASSWORD=matrix
POSTGRES_DB=matrixhub


DERIVE_TOOLS_FROM_MCP=true

# -------------------------
# IBM watsonx
WATSONX_API_KEY=
WATSONX_URL=
WATSONX_PROJECT_ID=
MODEL_ID=ibm/granite-3-3-8b-instruct
